						<span id="line2" class="hamburger-line block w-5 h-0.5 bg-text-dark rounded-full"></span>
						<span id="line3" class="hamburger-line block w-5 h-0.5 bg-text-dark rounded-full"></span>
					</button>
				</div>
			</div>
		</nav>

		<main>
			{{ content | safe }}
