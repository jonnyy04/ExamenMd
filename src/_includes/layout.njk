	<body class="font-body bg-white text-text-dark">
		<!-- ===== MOBILE MENU ===== -->
		<div id="mobile-menu" class="hidden fixed inset-0 z-[9999] bg-white flex flex-col">
			<div class="flex justify-between items-center px-6 py-4 border-b border-border-color">
				<span class="font-display text-xl font-bold text-primary-purple">Examen.md</span>
				<button id="close-menu" class="p-2 rounded-lg hover:bg-gray-100" aria-label="Închide meniu">
					<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
					</svg>
				</button>
			</div>
			<nav class="flex flex-col gap-1 px-4 py-6 flex-1">
				<a href="#courses" class="mobile-link text-lg font-semibold py-4 px-4 rounded-xl hover:bg-purple-50 hover:text-primary-purple transition-colors">Cursuri</a>
				<a href="#teachers" class="mobile-link text-lg font-semibold py-4 px-4 rounded-xl hover:bg-purple-50 hover:text-primary-purple transition-colors">Profesori</a>
				<a href="#about" class="mobile-link text-lg font-semibold py-4 px-4 rounded-xl hover:bg-purple-50 hover:text-primary-purple transition-colors">Despre</a>
				<a href="#contact" class="mobile-link text-lg font-semibold py-4 px-4 rounded-xl hover:bg-purple-50 hover:text-primary-purple transition-colors">Contact</a>
			</nav>
			<div class="px-6 py-6 border-t border-border-color">
				<a href="#contact" class="mobile-link block w-full text-center px-8 py-4 rounded-full font-semibold text-white bg-gradient-to-r from-primary-purple to-primary-dark-purple shadow-lg">Înscrie-te Gratuit</a>
			</div>
		</div>

		<!-- ===== NAVBAR ===== -->
		<nav class="sticky top-0 z-[1000] bg-white shadow-md py-3 md:py-4">
			<div class="max-w-6xl mx-auto px-4 sm:px-6 md:px-8 flex justify-between items-center gap-4">
				<a href="/"><img src="/img/Logo.png" alt="Examen.md" class="h-7 md:h-8 w-auto max-w-[160px] object-contain" /></a>
				<ul class="hidden lg:flex list-none gap-8 flex-1">
					<li><a href="#courses" class="font-medium hover:text-primary-purple transition-colors">Cursuri</a></li>
					<li><a href="#teachers" class="font-medium hover:text-primary-purple transition-colors">Profesori</a></li>
					<li><a href="#about" class="font-medium hover:text-primary-purple transition-colors">Despre</a></li>
					<li><a href="#contact" class="font-medium hover:text-primary-purple transition-colors">Contact</a></li>
				</ul>
				<div class="flex items-center gap-3">
					<a href="#contact" class="hidden lg:inline-block px-6 xl:px-8 py-3 rounded-full font-semibold text-white bg-gradient-to-r from-primary-purple to-primary-dark-purple hover:-translate-y-0.5 hover:shadow-lg transition-all text-sm">Înscrie-te</a>
					<button id="open-menu" class="lg:hidden flex flex-col justify-center items-center w-10 h-10 rounded-lg hover:bg-gray-100 gap-1.5" aria-label="Meniu">
