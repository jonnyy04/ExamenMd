		<!-- ===== MASCOT ===== -->
		<div id="mascot-peek">
			<img src="/img/mascot.png" alt="Mascota" />
		</div>

		<div id="mascot-wrapper">
			<div id="mascot-bubble">
				<button id="bubble-close" aria-label="Închide" style="position: absolute; top: -10px; right: -10px; width: 22px; height: 22px; background: #a535f0; border: none; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center">
					<svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round">
						<line x1="2" y1="2" x2="8" y2="8" />
						<line x1="8" y1="2" x2="2" y2="8" />
					</svg>
				</button>

				<p style="margin: 0 0 4px 0; font-family: &quot;Playfair Display&quot;, serif; font-weight: 700; font-size: 14px; color: #a535f0">Bun venit la Examen.md!</p>
				<p style="margin: 0 0 10px 0; font-size: 12px; color: #666; line-height: 1.6">Pregătire cu profesori calificați. Înscrie-te la o <strong style="color: #1a1a1a">lecție gratuită</strong> astăzi!</p>
				<p style="margin: 0 0 8px 0; font-size: 10px; text-transform: uppercase; letter-spacing: 0.06em; color: #999; font-weight: 600">Contactează-ne pe:</p>

				<div style="display: flex; gap: 8px">
					<a href="https://facebook.com" target="_blank" rel="noopener" class="mascot-social" style="background: #1877f2">
						<span class="tip">Facebook</span>
						<svg width="16" height="16" viewBox="0 0 24 24" fill="#fff"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" /></svg>
					</a>
					<a href="https://www.instagram.com/examen.md/" target="_blank" rel="noopener" class="mascot-social" style="background: linear-gradient(135deg, #f9ce34, #ee2a7b, #6228d7)">
						<span class="tip">Instagram</span>
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" /><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" /><line x1="17.5" y1="6.5" x2="17.51" y2="6.5" /></svg>
					</a>
					<a href="https://wa.me/37368334060" target="_blank" rel="noopener" class="mascot-social" style="background: #25d366">
						<span class="tip">WhatsApp</span>
						<svg width="16" height="16" viewBox="0 0 24 24" fill="#fff"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z" /></svg>
					</a>
					<a href="https://t.me/examenmd" target="_blank" rel="noopener" class="mascot-social" style="background: #229ed9">
						<span class="tip">Telegram</span>
						<svg width="16" height="16" viewBox="0 0 24 24" fill="#fff"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z" /></svg>
					</a>
				</div>
			</div>

			<div id="mascot-img-wrap" style="cursor: pointer; align-self: flex-end; filter: drop-shadow(0 8px 18px rgba(165, 53, 240, 0.3))">
				<img id="mascot-img" src="/img/mascot.png" alt="Mascota Examen.md" />
			</div>
		</div>

		<!-- ===== SCRIPTS ===== -->
		<script>
			/* ── Mobile menu ── */
			const openBtn = document.getElementById("open-menu");
			const closeBtn = document.getElementById("close-menu");
			const menu = document.getElementById("mobile-menu");

			function openMenu() {
				menu.classList.remove("hidden");
				document.body.classList.add("menu-open");
				document.body.style.overflow = "hidden";
			}
			function closeMenu() {
				menu.classList.add("hidden");
				document.body.classList.remove("menu-open");
				document.body.style.overflow = "";
			}

			openBtn.addEventListener("click", openMenu);
			closeBtn.addEventListener("click", closeMenu);
			document.querySelectorAll(".mobile-link").forEach((l) => l.addEventListener("click", closeMenu));
			menu.addEventListener("click", (e) => {
				if (e.target === menu) closeMenu();
			});

			/* ── Hero Carousel ── */
			(function () {
				const slides = document.querySelectorAll("#hero-carousel .hero-slide");
				if (slides.length) {
					let current = 0;
					setInterval(() => {
						slides[current].classList.remove("active");
						current = (current + 1) % slides.length;
						slides[current].classList.add("active");
					}, 4000);
				}
			})();

			/* ── Teacher Carousel ── */
			(function () {
				const track = document.getElementById("teacher-track");
				const prevBtn = document.getElementById("teacher-prev");
				const nextBtn = document.getElementById("teacher-next");
				const dotsWrap = document.getElementById("teacher-dots");
				if (!track) return;

				const slides = track.querySelectorAll(".teacher-slide");
				const total = slides.length;
				let page = 0;

				function getPerPage() {
					if (window.innerWidth >= 1024) return 5;
					if (window.innerWidth >= 640) return 3;
					return 2;
				}

				function getPages() {
					return Math.max(1, Math.ceil(total / getPerPage()));
				}

				function buildDots() {
					dotsWrap.innerHTML = "";
					var pages = getPages();
					if (pages <= 1) return;
					for (var i = 0; i < pages; i++) {
						var dot = document.createElement("button");
						dot.className = "w-2.5 h-2.5 rounded-full transition-all " + (i === page ? "bg-primary-purple scale-125" : "bg-white/40 hover:bg-white/60");
						dot.setAttribute("aria-label", "Pagina " + (i + 1));
						dot.dataset.page = i;
						dot.addEventListener("click", function () { goTo(parseInt(this.dataset.page)); });
						dotsWrap.appendChild(dot);
					}
				}

				function goTo(p) {
					var pages = getPages();
					page = Math.max(0, Math.min(p, pages - 1));
					var perPage = getPerPage();
					var gap = 20; /* 1.25rem = 20px */
					var containerWidth = track.parentElement.offsetWidth;
					var slideWidth = (containerWidth - gap * (perPage - 1)) / perPage;
					var offset = page * perPage * (slideWidth + gap);
					var maxOffset = total * (slideWidth + gap) - gap - containerWidth;
					track.style.transform = "translateX(-" + Math.min(offset, Math.max(0, maxOffset)) + "px)";
					buildDots();
					if (prevBtn) prevBtn.style.display = pages <= 1 ? "none" : "";
					if (nextBtn) nextBtn.style.display = pages <= 1 ? "none" : "";
				}

				if (prevBtn) prevBtn.addEventListener("click", function () { goTo(page - 1); });
				if (nextBtn) nextBtn.addEventListener("click", function () { goTo(page + 1); });

				goTo(0);
				var resizeTimer;
				window.addEventListener("resize", function () {
					clearTimeout(resizeTimer);
					resizeTimer = setTimeout(function () { goTo(page); }, 150);
				});
			})();

			/* ── Counter Animation ── */
			(function () {
				const counters = document.querySelectorAll('.counter');
				const duration = 2000;

				function animateCounter(el) {
					const target = parseInt(el.dataset.target);
					const suffix = el.dataset.suffix || '';
					const separator = el.dataset.separator || '';
					const start = performance.now();

					function update(now) {
						const progress = Math.min((now - start) / duration, 1);
						const eased = 1 - Math.pow(1 - progress, 3);
						const current = Math.floor(eased * target);
						el.textContent = (separator ? current.toLocaleString('en-US') : current) + suffix;
						if (progress < 1) requestAnimationFrame(update);
					}
					requestAnimationFrame(update);
				}

				const observer = new IntersectionObserver(function (entries) {
					entries.forEach(function (entry) {
						if (entry.isIntersecting) {
							animateCounter(entry.target);
							observer.unobserve(entry.target);
						}
					});
				}, { threshold: 0.5 });

				counters.forEach(function (c) { observer.observe(c); });
			})();

			/* ── Mascot ── */
			const wrapper = document.getElementById("mascot-wrapper");
			const bubble = document.getElementById("mascot-bubble");
			const bubbleClose = document.getElementById("bubble-close");
			const imgWrap = document.getElementById("mascot-img-wrap");
			const mascotImg = document.getElementById("mascot-img");
			const peek = document.getElementById("mascot-peek");

			setTimeout(() => { wrapper.classList.add("visible"); }, 2500);
			imgWrap.addEventListener("click", () => bubble.classList.toggle("open"));
			bubbleClose.addEventListener("click", (e) => { e.stopPropagation(); bubble.classList.remove("open"); });
			imgWrap.addEventListener("dblclick", () => {
				bubble.classList.remove("open");
				wrapper.classList.remove("visible");
				setTimeout(() => peek.classList.add("visible"), 500);
			});
			peek.addEventListener("click", () => { peek.classList.remove("visible"); wrapper.classList.add("visible"); });
			setInterval(() => {
				if (!wrapper.classList.contains("visible")) return;
				mascotImg.classList.add("wiggle");
				mascotImg.addEventListener("animationend", () => mascotImg.classList.remove("wiggle"), { once: true });
			}, 8000);
		</script>
	</body>
</html>
